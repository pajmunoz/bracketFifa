# Copia a .env local o define estas variables en Vercel → Settings → Environment Variables.
# La base de datos debe aceptar conexiones desde internet (no solo localhost) para que
# las serverless functions de Vercel puedan conectar.

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# URL pública del sitio (sin barra final). Necesaria para metadatos Open Graph en /entrada/[id]
# (imagen generada en /api/entrada/[id]/og). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Opcional: app de Meta (Facebook) para el diálogo dialog/share con texto (quote) y enlace (href).
# En la app → Facebook Login → Settings → Valid OAuth Redirect URIs, añade exactamente:
# https://www.facebook.com/dialog/return/close
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Opcional: límite de conexiones del pool (por defecto 3; en serverless conviene bajo).
DB_POOL_LIMIT=3

# Opcional: SSL (p. ej. PlanetScale, RDS, o hosting que exija TLS)
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
